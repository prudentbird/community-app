# NEXT.JS / VERCEL
# Set these in .env.local for local dev, and in Vercel for production.

# Get these from https://dashboard.convex.dev or by running `npx convex dev`
CONVEX_DEPLOYMENT=                  # e.g. dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=             # e.g. https://<deployment>.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=        # e.g. https://<deployment>.convex.site

# App URL
SITE_URL=                           # e.g. http://localhost:3000 (server-side)
NEXT_PUBLIC_SITE_URL=               # e.g. http://localhost:3000 (client-side)

# CONVEX
# Set these via the Convex dashboard or: npx convex env set <KEY> <value>
SITE_URL=
BETTER_AUTH_SECRET=

# Optional: Convex deploy key (CI/CD only)
CONVEX_DEPLOY_KEY=

# Optional: set to "1" or "true" to skip env validation during builds
SKIP_ENV_VALIDATION=
